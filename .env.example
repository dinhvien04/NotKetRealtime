STORAGE_PROVIDER=s3
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_TTL_SECONDS=3600
S3_PRESIGNED_UPLOAD_TTL_SECONDS=300
MAX_UPLOAD_BYTES=6291456
MAX_IMAGE_BYTES=6291456
MAX_VOICE_BYTES=10485760
