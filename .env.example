SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
PASSWORD_RESET_OTP_TTL_MINUTES=10
OTP_PEPPER=
MAX_AVATAR_BYTES=2097152
MESSAGE_EDIT_WINDOW_MINUTES=15

AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_RATE_LIMIT_PER_MINUTE=10
AI_MAX_INPUT_CHARS=4000

ENABLE_REDIS_ADAPTER=false
