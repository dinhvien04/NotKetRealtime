NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
APP_BASE_URL=http://localhost:3000

DATABASE_URL=
MIGRATION_DATABASE_URL=

JWT_SECRET=
JWT_EXPIRES_IN=7d
COOKIE_NAME=notket_token
CSRF_COOKIE_NAME=notket_csrf
